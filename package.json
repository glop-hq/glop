{
  "name": "glop",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @glop/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @glop/db generate",
    "db:migrate": "pnpm --filter @glop/db migrate",
    "seed": "pnpm --filter @glop/web seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}

{
  "name": "glop.dev",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "glop": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
